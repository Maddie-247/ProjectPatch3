#line 117 "/Engine/Private/Lumen/LumenHardwareRayTracingCommon.ush"
float ClipAndDitherNearFieldMaxTraceDistance(
	float3 TranslatedWorldRayOrigin,
	float3 RayDirection,
	uint2 NoiseCoord,
	float NearFieldSceneRadius,
	float NearFieldMaxTraceDistance,
	float NearFieldMaxTraceDistanceDitherScale)
{
	float ClippedNearFieldMaxTraceDistance = 0.0f;

	float2 RaySphereHit = RayIntersectSphere(TranslatedWorldRayOrigin, RayDirection, float4(GetPrimaryView().TranslatedWorldCameraOrigin, NearFieldSceneRadius));
	if (RaySphereHit.x < 0.0f && RaySphereHit.y > 0.0f)
	{
		ClippedNearFieldMaxTraceDistance = min(RaySphereHit.y, NearFieldMaxTraceDistance) - InterleavedGradientNoise(NoiseCoord, View_StateFrameIndexMod8) * NearFieldMaxTraceDistanceDitherScale;
	}

	return ClippedNearFieldMaxTraceDistance;
}

