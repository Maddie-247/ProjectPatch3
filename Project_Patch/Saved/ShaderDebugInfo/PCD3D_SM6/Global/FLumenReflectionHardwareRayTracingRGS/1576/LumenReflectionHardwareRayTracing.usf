{
	float W; 
	float E; 
};
FBxDFEnergyTermsA   ComputeClothEnergyTermsA(float Roughness, float NoV)
{
	  FBxDFEnergyTermsA Out;
	{
		Out.W = 1.0f;
		Out.E = 1.0f;
	}
	return Out;
}
float ComputeEnergyPreservation(  FBxDFEnergyTermsA EnergyTerms)
{
	return 1.0f;
}
