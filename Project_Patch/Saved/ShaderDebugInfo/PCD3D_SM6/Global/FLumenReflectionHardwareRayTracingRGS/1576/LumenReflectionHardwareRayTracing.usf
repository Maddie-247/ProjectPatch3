typedef Texture2D SafeTypeOpacityAtlas;SafeTypeOpacityAtlas GetBindlessResourceOpacityAtlas() { return ResourceDescriptorHeap[NonUniformResourceIndex(BindlessSRV_OpacityAtlas)]; } static const SafeTypeOpacityAtlas OpacityAtlas = GetBindlessResourceOpacityAtlas();
